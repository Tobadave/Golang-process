		if r.URL.Path != "/" {
			http.Error(w, "FILE NOT FOUND", http.StatusNotFound)
			return
		}

		tmpl, err := template.ParseFiles("index.html")
		if err != nil {
			http.Error(w, "Error loading files", http.StatusInternalServerError)
			return
